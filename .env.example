APP_NAME=FetNet
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://fetnet.techupi.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=fetnet
DB_USERNAME=fetnet
DB_PASSWORD=Ddw8436

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@fetnet.id"
MAIL_FROM_NAME="${APP_NAME}"

# CAS SSO UPI
CAS_HOSTNAME=sso.upi.edu
CAS_PORT=443
CAS_URI=/cas
CAS_VERSION=3.0
CAS_LOGOUT_URL=https://sso.upi.edu/cas/logout

# Trust proxy headers (behind reverse proxy → set true so APP_URL scheme detected)
TRUSTED_PROXIES=*

VITE_APP_NAME="${APP_NAME}"
